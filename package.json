{
  "name": "medieval-realm-monorepo",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "bcrypt", "esbuild"]
  },
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:frontend": "pnpm --filter @medieval-realm/frontend dev",
    "dev:backend": "pnpm --filter @medieval-realm/backend dev",
    "db:push": "pnpm --filter @medieval-realm/backend db:push",
    "db:migrate": "pnpm --filter @medieval-realm/backend db:migrate"
  }
}
