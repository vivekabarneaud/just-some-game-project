datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  settlements  Settlement[]
  tradeOffersSold   TradeOffer[] @relation("TradeOffersSold")
  tradeOffersBought TradeOffer[] @relation("TradeOffersBought")
  friendshipsRequested Friendship[] @relation("FriendshipRequester")
  friendshipsReceived  Friendship[] @relation("FriendshipAddressee")
  coopsHosted          CoopExpedition[] @relation("CoopExpeditionHost")
  coopsGuested         CoopExpedition[] @relation("CoopExpeditionGuest")
}

model CoopExpedition {
  id             String   @id @default(cuid())
  hostId         String
  guestId        String
  expeditionId   String   // template id (from EXPEDITION_POOL)
  status         String   @default("pending") // pending | preparing | active | complete | cancelled
  // Rosters — JSON { adventurerIds: string[], supplies: Record<string, {potion?,food?,recovery?}> }
  hostRoster     Json?
  guestRoster    Json?
  // Ready flags — when both true, expedition auto-deploys
  hostReady      Boolean  @default(false)
  guestReady     Boolean  @default(false)
  // Runtime state once complete — holds the simulation result (rewards, adventurer deltas, combat log)
  runtimeState   Json?
  // Per-player claim tracking — becomes true once that side has applied rewards locally
  hostClaimed    Boolean  @default(false)
  guestClaimed   Boolean  @default(false)
  deployedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  host  Player @relation("CoopExpeditionHost", fields: [hostId], references: [id])
  guest Player @relation("CoopExpeditionGuest", fields: [guestId], references: [id])

  @@index([hostId, status])
  @@index([guestId, status])
}

model Friendship {
  id           String   @id @default(cuid())
  requesterId  String
  addresseeId  String
  status       String   @default("pending") // pending | accepted
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requester Player @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee Player @relation("FriendshipAddressee", fields: [addresseeId], references: [id])

  // A pair of players can only have one friendship row
  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model World {
  id             String       @id @default(cuid())
  name           String       @unique
  width          Int          @default(1000)
  height         Int          @default(1000)
  maxSettlements Int          @default(50)
  createdAt      DateTime     @default(now())
  settlements    Settlement[]
}

model Settlement {
  id         String   @id @default(cuid())
  playerId   String
  worldId    String
  name       String
  x          Int
  y          Int
  gameState  Json
  lastTickAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])
  world  World  @relation(fields: [worldId], references: [id])
  tradeOffersFrom TradeOffer[] @relation("TradeOffersFromSettlement")
  tradeOffersTo   TradeOffer[] @relation("TradeOffersToSettlement")

  @@index([playerId])
  @@index([worldId])
}

model TradeOffer {
  id               String    @id @default(cuid())
  sellerId         String
  sellerSettId     String
  buyerId          String?
  buyerSettId      String?
  status           String    @default("open") // open | accepted | completed | cancelled
  giveResource     String
  giveAmount       Int
  receiveResource  String
  receiveAmount    Int
  distance         Float?
  caravanArrivesAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  seller     Player      @relation("TradeOffersSold", fields: [sellerId], references: [id])
  sellerSett Settlement  @relation("TradeOffersFromSettlement", fields: [sellerSettId], references: [id])
  buyer      Player?     @relation("TradeOffersBought", fields: [buyerId], references: [id])
  buyerSett  Settlement? @relation("TradeOffersToSettlement", fields: [buyerSettId], references: [id])

  @@index([status])
  @@index([sellerId])
  @@index([buyerId])
  @@index([status, caravanArrivesAt])
}
