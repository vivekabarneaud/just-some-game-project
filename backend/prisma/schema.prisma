datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  settlements  Settlement[]
  tradeOffersSold   TradeOffer[] @relation("TradeOffersSold")
  tradeOffersBought TradeOffer[] @relation("TradeOffersBought")
}

model World {
  id             String       @id @default(cuid())
  name           String       @unique
  width          Int          @default(1000)
  height         Int          @default(1000)
  maxSettlements Int          @default(50)
  createdAt      DateTime     @default(now())
  settlements    Settlement[]
}

model Settlement {
  id         String   @id @default(cuid())
  playerId   String
  worldId    String
  name       String
  x          Int
  y          Int
  gameState  Json
  lastTickAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])
  world  World  @relation(fields: [worldId], references: [id])
  tradeOffersFrom TradeOffer[] @relation("TradeOffersFromSettlement")
  tradeOffersTo   TradeOffer[] @relation("TradeOffersToSettlement")

  @@index([playerId])
  @@index([worldId])
}

model TradeOffer {
  id               String    @id @default(cuid())
  sellerId         String
  sellerSettId     String
  buyerId          String?
  buyerSettId      String?
  status           String    @default("open") // open | accepted | completed | cancelled
  giveResource     String
  giveAmount       Int
  receiveResource  String
  receiveAmount    Int
  distance         Float?
  caravanArrivesAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  seller     Player      @relation("TradeOffersSold", fields: [sellerId], references: [id])
  sellerSett Settlement  @relation("TradeOffersFromSettlement", fields: [sellerSettId], references: [id])
  buyer      Player?     @relation("TradeOffersBought", fields: [buyerId], references: [id])
  buyerSett  Settlement? @relation("TradeOffersToSettlement", fields: [buyerSettId], references: [id])

  @@index([status])
  @@index([sellerId])
  @@index([buyerId])
  @@index([status, caravanArrivesAt])
}
